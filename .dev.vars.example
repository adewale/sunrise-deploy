# Sunrise first-boot secrets.
# Cloudflare Deploy uses this file plus package.json cloudflare.bindings descriptions
# to prompt deploy-button users for required values.

GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
OWNER_LOGIN=""
SESSION_SECRET=""
# Optional: add `repo` only if you need private repository discovery.
GITHUB_OAUTH_SCOPES="read:user user:email notifications"
# Local-only helper; do not enable in production.
TEST_GITHUB_FIXTURES="true"
